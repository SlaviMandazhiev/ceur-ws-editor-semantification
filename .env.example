# CEUR-DEV API credentials
# These are issued by the RWTH Aachen CS5 chair for access to their CEUR-DEV Wikibase instance.
# Without these, the upload steps of the pipeline will not work.
USERNAME=your_ceurdev_username
PASSWORD=your_ceurdev_password

# LLM Provider — choose one: ollama, openai, anthropic (default: ollama)
LLM_PROVIDER=ollama

# Model name for the chosen provider
# Ollama examples:   llama3.1:8b, llama3.3:70b, qwen2.5:7b
# OpenAI examples:   gpt-4o-mini, gpt-4o
# Anthropic examples: claude-haiku-4-5-20251001, claude-sonnet-4-6
LLM_MODEL=llama3.1:8b

# Ollama: base URL of your Ollama server (only needed when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI: only needed when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Anthropic: only needed when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
